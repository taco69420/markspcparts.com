---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PartCard from '../components/PartCard.astro';

const parts = [
  {
    name: 'ASUS Z10PE-D16 + Dual Xeon E5-2620 v4',
    category: 'Motherboard',
    specs: ['Dual LGA 2011-3 · C612 chipset', '2x 8C/16T Xeon E5-2620 v4 included', '16x DDR4 ECC DIMM slots · up to 1TB', 'IPMI 2.0 · KVM over IP · remote management'],
    condition: 'Good' as const,
    status: 'Available' as const,
    description: 'Complete dual-socket DDR4 ECC workstation platform. Tested and confirmed working. Full IPMI/BMC onboard — KVM over IP, remote power, headless management. $200 on eBay.',
    image: '/images/posts/dual-socket-16/hero-dual.jpg',
    href: '/inventory/z10pe-d16',
    ebayUrl: 'https://ebay.io/m/4Yi0ug',
  },
  {
    name: 'Micron 64GB DDR4 ECC RDIMM Kit (4x 16GB)',
    category: 'RAM',
    specs: ['4x 16GB Micron MTA18ASF2G72PDZ-2G3B1IK', 'DDR4-2400 · PC4-2400T · 2Rx8', 'ECC Registered (RDIMM) · 288-pin', 'LGA 2011-3 · C612 / C602 compatible'],
    condition: 'Good' as const,
    status: 'Available' as const,
    description: 'Matched 64GB DDR4 ECC RDIMM kit pulled from a working ASUS Z10PE-D16 dual-socket system. All 4 sticks confirmed in BIOS before removal. $200 on eBay.',
    image: '/images/posts/ram-sale/hero-ram.jpg',
    href: '/inventory/micron-64gb-ddr4-ecc',
    ebayUrl: 'https://ebay.io/m/DMX5Pr',
  },
  {
    name: 'Noctua NH-D9DX i4 3U — LGA 2011 Square-ILM',
    category: 'Cooler',
    specs: ['Noctua NF-A9 92mm PWM fan', 'LGA 2011 Square-ILM bracket included', '95mm height — fits 3U+', 'No Allen key included — read listing'],
    condition: 'Fair' as const,
    status: 'Available' as const,
    description: 'Used Noctua NH-D9DX i4 3U pulled from a working dual-socket Xeon system. Some cosmetic wear and minor fin bends — priced accordingly. No Allen key or accessories. $50 + $15 shipping.',
    image: '/images/posts/noctua-sale/side-2-noc.jpg',
    href: '/inventory/noctua-nh-d9dx-i4-3u',
    ebayUrl: 'https://ebay.io/m/I1uf7I',
  },
  {
    name: 'NVIDIA Titan RTX',
    category: 'GPU',
    specs: ['24 GB GDDR6 · 384-bit bus', 'Turing TU102 · 4608 CUDA cores', 'NVLink support', 'Museum condition — display only'],
    condition: 'Mint' as const,
    status: 'Not Listed' as const,
    description: 'Museum-condition NVIDIA Titan RTX — 24 GB GDDR6, NVLink support. Picked up from a local collector who only ever powered it on to test it.',
    image: '/images/inventory/titan-rtx/titan1.jpg',
    href: '/inventory/titan-rtx',
  },
  {
    name: 'ASUS ROG Dominus Extreme',
    category: 'Motherboard',
    specs: ['Intel LGA 3647 · C621 chipset', 'W-3175X only (28C/56T)', '12x DDR4 DIMM · 192GB max', 'Complete with all original accessories'],
    condition: 'Good' as const,
    status: 'Not Listed' as const,
    description: 'ASUS ROG Dominus Extreme LGA 3647 motherboard — fully working, complete with original accessories. Might list later.',
    image: '/images/inventory/rog-dominus-extreme/rogdom2.jpg',
    href: '/inventory/rog-dominus-extreme',
  },
  {
    name: 'Intel Xeon W-3175X',
    category: 'CPU',
    specs: ['28 cores / 56 threads · Unlocked', 'LGA 3647 · Dominus Extreme only', '48 PCIe 3.0 lanes · 255W TDP', 'Fair cosmetic — solid silicon'],
    condition: 'Fair' as const,
    status: 'Not Listed' as const,
    description: 'Intel Xeon W-3175X — 28 cores, unlocked multiplier, LGA 3647. Fair cosmetic condition (IHS scratches), but silicon is solid. Might list later.',
    image: '/images/inventory/xeon-w-3175x/3175x1.jpg',
    href: '/inventory/xeon-w-3175x',
  },
];

const inventoryLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: "Mark's PC Parts — Inventory",
  description: 'Rare, collectible, and enthusiast PC hardware sourced, tested, and documented by Mark in Redlands, CA.',
  url: 'https://markspcparts.com/inventory',
  hasPart: parts.filter(p => p.status === 'Available').map(p => ({
    '@type': 'Product',
    name: p.name,
    url: `https://markspcparts.com${p.href}`,
    image: `https://markspcparts.com${p.image}`,
  })),
};
---

<Layout
  title="Inventory"
  description="Browse Mark's collection of rare, collectible, and enthusiast PC hardware. Available now: DDR4 ECC RAM, dual-socket workstation boards, and more."
  canonicalUrl="https://markspcparts.com/inventory"
  ogImage="https://markspcparts.com/images/posts/dual-socket-16/hero-dual.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(inventoryLd)} />
  </Fragment>
  <Nav slot="nav" />

  <!-- Page header -->
  <section class="border-b border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-3">Browse</p>
      <h1 class="text-3xl sm:text-4xl font-bold">Inventory</h1>
      <p class="mt-3 text-steel max-w-lg">
        Every piece sourced, tested, and written up. Available items are ready to sell —
        sold items link to their eBay listing for reference.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-white/5 bg-surface-800/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center gap-8 text-sm">
      <span class="text-steel">
        <span class="text-slate-100 font-semibold">{parts.filter(p => p.status === 'Available').length}</span> available
      </span>
      <span class="text-steel">
        <span class="text-amber-300 font-semibold">{parts.filter(p => p.status === 'Not Listed').length}</span> not listed
      </span>
      <span class="text-steel">
        <span class="text-slate-100 font-semibold">{parts.filter(p => p.status === 'Sold').length}</span> sold
      </span>
      <span class="text-steel ml-auto text-xs font-mono">
        {parts.length} total parts
      </span>
    </div>
  </section>

  <!-- Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {parts.map(part => <PartCard {...part} />)}
    </div>

    <!-- Empty state placeholder (hidden when parts exist) -->
    {parts.length === 0 && (
      <div class="text-center py-24 text-steel">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <p class="font-medium">No parts listed yet.</p>
        <p class="text-sm mt-1">Check back soon.</p>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</Layout>
