---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PartCard from '../components/PartCard.astro';
import { readingTime } from '../lib/readingTime';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "Mark's PC Parts",
  url: 'https://markspcparts.com',
  description: 'Rare, collectible, and enthusiast PC hardware sourced, tested, and documented by Mark in Redlands, CA.',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://markspcparts.com/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: "Mark's PC Parts",
  url: 'https://markspcparts.com',
  description: 'Rare, collectible, and enthusiast PC hardware sourced, tested, and documented by Mark in Redlands, CA.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Redlands',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.tiktok.com/@tacoismybigboydaddy',
    'https://ebay.us/m/E2CfrF',
  ],
};

const featured = [
  {
    name: 'ASUS Z10PE-D16 + Dual Xeon E5-2620 v4',
    category: 'Motherboard',
    specs: ['Dual LGA 2011-3 · C612 chipset', '2x 8C/16T Xeon E5-2620 v4 included', '16x DDR4 ECC DIMM slots · up to 1TB', 'IPMI 2.0 · KVM over IP · remote management'],
    condition: 'Good' as const,
    status: 'Available' as const,
    description: 'Complete dual-socket DDR4 ECC workstation platform. Tested and confirmed working. Full IPMI/BMC onboard. $200 on eBay.',
    image: '/images/posts/dual-socket-16/hero-dual.jpg',
    href: '/inventory/z10pe-d16',
    ebayUrl: 'https://ebay.io/m/4Yi0ug',
  },
  {
    name: 'Micron 64GB DDR4 ECC RDIMM Kit (4x 16GB)',
    category: 'RAM',
    specs: ['4x 16GB Micron MTA18ASF2G72PDZ-2G3B1IK', 'DDR4-2400 · PC4-2400T · 2Rx8', 'ECC Registered (RDIMM) · 288-pin', 'LGA 2011-3 · C612 / C602 compatible'],
    condition: 'Good' as const,
    status: 'Available' as const,
    description: 'Matched 64GB DDR4 ECC RDIMM kit pulled from a working ASUS Z10PE-D16 dual-socket system. All 4 sticks confirmed in BIOS before removal. $200 on eBay.',
    image: '/images/posts/ram-sale/hero-ram.jpg',
    href: '/inventory/micron-64gb-ddr4-ecc',
    ebayUrl: 'https://ebay.io/m/DMX5Pr',
  },
  {
    name: 'Noctua NH-D9DX i4 3U — LGA 2011 Square-ILM',
    category: 'Cooler',
    specs: ['Noctua NF-A9 92mm PWM fan', 'LGA 2011 Square-ILM bracket included', '95mm height — fits 3U+', 'No Allen key included — read listing'],
    condition: 'Fair' as const,
    status: 'Available' as const,
    description: 'Used Noctua NH-D9DX i4 3U pulled from a working dual-socket Xeon system. Minor cosmetic wear and fin bends — priced accordingly. No Allen key. $50 + $15 shipping.',
    image: '/images/posts/noctua-sale/side-2-noc.jpg',
    href: '/inventory/noctua-nh-d9dx-i4-3u',
    ebayUrl: 'https://ebay.io/m/I1uf7I',
  },
];
---

<Layout
  title="Rare &amp; Enthusiast PC Hardware"
  description="Rare, collectible, and enthusiast PC hardware sourced, tested, and documented. Redlands, CA."
  canonicalUrl="https://markspcparts.com/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
  </Fragment>
  <Nav slot="nav" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-surface-900">
    <!-- Grid background -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(124,58,237,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(124,58,237,0.03)_1px,transparent_1px)] bg-[size:48px_48px]" aria-hidden="true"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_-20%,rgba(124,58,237,0.15),transparent)]" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28 sm:py-36 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-xs font-mono text-accent-light mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-light animate-pulse"></span>
        Redlands, CA · Rare &amp; Enthusiast Hardware
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
        Hardware too rare<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-light to-violet-300">
          to leave in a landfill
        </span>
      </h1>

      <p class="mt-6 max-w-xl mx-auto text-lg text-steel leading-relaxed">
        Collectible CPUs, legendary GPUs, and enthusiast boards — each piece sourced,
        tested, and documented. Explore the inventory or follow the builds on TikTok.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/inventory"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent/90 transition-colors shadow-lg shadow-accent/25"
        >
          Browse Inventory
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-white/10 text-steel hover:text-slate-100 hover:border-white/20 font-medium text-sm transition-colors"
        >
          About Mark
        </a>
      </div>
    </div>
  </section>

  <!-- Featured listings -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-2">Featured</p>
        <h2 class="text-2xl sm:text-3xl font-bold">Recent Finds</h2>
      </div>
      <a href="/inventory" class="text-sm text-steel hover:text-accent-light transition-colors font-medium hidden sm:block">
        View all →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map(part => <PartCard {...part} />)}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a href="/inventory" class="text-sm text-steel hover:text-accent-light transition-colors font-medium">
        View all inventory →
      </a>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-2">Blog</p>
        <h2 class="text-2xl sm:text-3xl font-bold">Recent Posts</h2>
      </div>
      <a href="/blog" class="text-sm text-steel hover:text-accent-light transition-colors font-medium hidden sm:block">
        View all →
      </a>
    </div>

    <ul class="divide-y divide-white/5">
      {recentPosts.map(post => {
        const dateStr = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          timeZone: 'UTC',
        });
        return (
          <li class="py-8 group">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-6">
                  <div class="flex items-center gap-2 shrink-0 mb-2 sm:mb-0">
                    <time class="text-xs font-mono text-steel">{dateStr}</time>
                    <span class="text-white/15 text-xs hidden sm:inline">·</span>
                    <span class="text-xs font-mono text-steel hidden sm:inline">{readingTime(post.body)}</span>
                  </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-medium text-slate-100 group-hover:text-accent-light transition-colors mb-1">
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="text-steel text-sm leading-relaxed mb-3">{post.data.description}</p>
                  )}
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {post.data.tags.map(tag => (
                        <span class="text-xs font-mono px-2 py-0.5 rounded bg-surface-700 text-steel border border-white/5">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <span class="hidden sm:inline-block shrink-0 text-accent-light opacity-0 group-hover:opacity-100 transition-opacity text-sm">
                  →
                </span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <div class="mt-8 text-center sm:hidden">
      <a href="/blog" class="text-sm text-steel hover:text-accent-light transition-colors font-medium">
        View all posts →
      </a>
    </div>
  </section>

  <!-- About blurb -->
  <section class="border-t border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-4">About Mark</p>
        <h2 class="text-2xl sm:text-3xl font-bold mb-5">Collector. Flipper. Creator.</h2>
        <p class="text-steel leading-relaxed">
          Based in Redlands, CA — I source rare and enthusiast PC hardware, document it properly,
          and find it a new home. Every piece gets a full write-up with specs, condition notes, and
          backstory. Follow my builds and finds on TikTok.
        </p>
        <a href="/about" class="inline-block mt-6 text-sm text-accent-light hover:text-white transition-colors font-medium">
          Read more about me →
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
