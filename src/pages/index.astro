---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PartCard from '../components/PartCard.astro';

const featured = [
  {
    name: 'Intel Xeon W-3175X',
    category: 'CPU',
    specs: ['LGA 3647 · 28C / 56T', 'Unlocked multiplier', '6-ch DDR4 · 48 PCIe lanes', '255W TDP'],
    condition: 'Fair' as const,
    status: 'Available' as const,
    description: 'The only consumer 28-core Intel ever made. Cosmetic wear on IHS, solid silicon. Price on request — message on eBay. Bundle with Dominus Extreme available.',
    image: '/3175x1.jpg',
    href: '/inventory/xeon-w-3175x',
    ebayUrl: 'https://ebay.us/m/ouUYQi',
  },
  {
    name: 'ASUS ROG Dominus Extreme',
    category: 'Motherboard',
    specs: ['Intel LGA 3647', 'Xeon W-3175X · 28C/56T', '12-ch DDR4 · 192 GB max', '4x PCIe 3.0 x16 · ROG Aura RGB'],
    condition: 'Good' as const,
    status: 'Available' as const,
    description: 'Flagship HEDT board for the Xeon W-3175X. Complete with accessories. POST code 00 issue — well-documented resistor fix. Active eBay listing.',
    image: '/rogdom2.jpg',
    href: '/inventory/rog-dominus-extreme',
    ebayUrl: 'https://ebay.us/m/KmIMET',
  },
  {
    name: 'NVIDIA Titan RTX',
    category: 'GPU',
    specs: ['24 GB GDDR6', 'Turing · 4608 CUDA cores', '672 GB/s bandwidth', 'NVLink support'],
    condition: 'Mint' as const,
    status: 'Watching' as const,
    description: 'Museum-condition Titan RTX from a local collector. Pristine shroud, gold accents untouched. Considering holding for a dual NVLink build.',
    image: '/titan1.jpg',
    href: '/inventory/titan-rtx',
  },
  {
    name: 'EVGA GTX 980 Ti SC+',
    category: 'GPU',
    specs: ['GM200 · Maxwell', '6 GB GDDR5', '384-bit bus', 'ACX 2.0+ Cooling'],
    condition: 'Mint' as const,
    status: 'Available' as const,
    description: 'Top-of-line Maxwell flagship. Barely used, full shroud intact, backplate pristine. A display-worthy card.',
  },
  {
    name: 'Asus Rampage IV Extreme',
    category: 'Motherboard',
    specs: ['LGA2011 · X79', '8x DDR3 slots · 64 GB max', 'Quad SLI / CrossFireX', 'ROG Supreme FX audio'],
    condition: 'Good' as const,
    status: 'Sold' as const,
    description: 'HEDT powerhouse from the X79 era. Fully tested, all phases confirmed. A proper enthusiast trophy board.',
    ebayUrl: '#',
  },
];
---

<Layout title="Home">
  <Nav slot="nav" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-surface-900">
    <!-- Grid background -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(124,58,237,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(124,58,237,0.03)_1px,transparent_1px)] bg-[size:48px_48px]" aria-hidden="true"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_-20%,rgba(124,58,237,0.15),transparent)]" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28 sm:py-36 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-xs font-mono text-accent-light mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-light animate-pulse"></span>
        Redlands, CA · Rare &amp; Enthusiast Hardware
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
        Hardware too rare<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-light to-violet-300">
          to leave in a landfill
        </span>
      </h1>

      <p class="mt-6 max-w-xl mx-auto text-lg text-steel leading-relaxed">
        Collectible CPUs, legendary GPUs, and enthusiast boards — each piece sourced,
        tested, and documented. Explore the inventory or follow the builds on TikTok.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/inventory"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent/90 transition-colors shadow-lg shadow-accent/25"
        >
          Browse Inventory
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-white/10 text-steel hover:text-slate-100 hover:border-white/20 font-medium text-sm transition-colors"
        >
          About Mark
        </a>
      </div>
    </div>
  </section>

  <!-- Featured listings -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-2">Featured</p>
        <h2 class="text-2xl sm:text-3xl font-bold">Recent Finds</h2>
      </div>
      <a href="/inventory" class="text-sm text-steel hover:text-accent-light transition-colors font-medium hidden sm:block">
        View all →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map(part => <PartCard {...part} />)}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a href="/inventory" class="text-sm text-steel hover:text-accent-light transition-colors font-medium">
        View all inventory →
      </a>
    </div>
  </section>

  <!-- About blurb -->
  <section class="border-t border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-4">About Mark</p>
        <h2 class="text-2xl sm:text-3xl font-bold mb-5">Collector. Flipper. Creator.</h2>
        <p class="text-steel leading-relaxed">
          Based in Redlands, CA — I source rare and enthusiast PC hardware, document it properly,
          and find it a new home. Every piece gets a full write-up with specs, condition notes, and
          backstory. Follow my builds and finds on TikTok.
        </p>
        <a href="/about" class="inline-block mt-6 text-sm text-accent-light hover:text-white transition-colors font-medium">
          Read more about me →
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
