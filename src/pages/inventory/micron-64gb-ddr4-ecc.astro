---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const ebayUrl = 'https://ebay.io/m/DMX5Pr';

const images = [
  { src: '/images/posts/ram-sale/hero-ram.jpg', alt: '4x Micron 16GB DDR4 ECC RDIMM — front side, matched set' },
  { src: '/images/posts/ram-sale/back-ram.jpg', alt: '4x Micron 16GB DDR4 ECC RDIMM — back side' },
  { src: '/images/posts/ram-sale/close-ram.jpg', alt: 'Micron MTA18ASF2G72PDZ-2G3B1IK label close-up — 16GB 2RX8 PC4-2400T' },
];

const specs = [
  { label: 'Part Number', value: 'MTA18ASF2G72PDZ-2G3B1IK' },
  { label: 'Total Capacity', value: '64GB (4x 16GB)' },
  { label: 'Type', value: 'DDR4 ECC Registered (RDIMM)' },
  { label: 'Speed', value: 'DDR4-2400 (PC4-2400T)' },
  { label: 'Rank / Width', value: '2Rx8' },
  { label: 'Form Factor', value: '288-pin DIMM' },
  { label: 'Brand', value: 'Micron' },
  { label: 'ECC', value: 'Yes — Error-Correcting Code' },
  { label: 'Registered', value: 'Yes — RDIMM' },
  { label: 'Compatibility', value: 'LGA 2011-3 / LGA 2011 · Intel C612, C602, C600 chipsets' },
  { label: 'Pulled From', value: 'ASUS Z10PE-D16 dual-socket workstation' },
  { label: 'Condition', value: 'Good — pulled from working system, all 4 sticks verified in BIOS' },
  { label: 'Shipping', value: 'USA only' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Micron 64GB DDR4 ECC RDIMM Kit (4x 16GB) MTA18ASF2G72PDZ-2G3B1IK',
  description: '4x Micron 16GB DDR4-2400 ECC RDIMM — matched set pulled from a working dual-socket workstation. All 4 sticks confirmed in BIOS before removal.',
  image: 'https://markspcparts.com/images/posts/ram-sale/hero-ram.jpg',
  url: 'https://markspcparts.com/inventory/micron-64gb-ddr4-ecc',
  brand: { '@type': 'Brand', name: 'Micron' },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    price: '200',
    url: ebayUrl,
    seller: { '@type': 'Person', name: 'Mark', url: 'https://markspcparts.com' },
  },
};
---

<Layout
  title="Micron 64GB DDR4 ECC RDIMM Kit (4x 16GB) — For Sale"
  description="Matched 4x 16GB Micron DDR4-2400 ECC RDIMM kit (MTA18ASF2G72PDZ-2G3B1IK). Pulled from working dual-socket system. $200 on eBay — USA shipping only."
  ogImage="https://markspcparts.com/images/posts/ram-sale/hero-ram.jpg"
  canonicalUrl="https://markspcparts.com/inventory/micron-64gb-ddr4-ecc"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Nav slot="nav" />

  <!-- Breadcrumb -->
  <div class="border-b border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center gap-2 text-xs text-steel font-mono">
      <a href="/" class="hover:text-accent-light transition-colors">home</a>
      <span class="text-white/20">/</span>
      <a href="/inventory" class="hover:text-accent-light transition-colors">inventory</a>
      <span class="text-white/20">/</span>
      <span class="text-slate-300">micron-64gb-ddr4-ecc</span>
    </div>
  </div>

  <!-- Status banner -->
  <div class="bg-accent/10 border-b border-accent/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
      <p class="text-sm text-accent-light font-medium">Available on eBay — $200 · USA shipping only</p>
      <a
        href={ebayUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-1.5 text-xs text-yellow-400 hover:text-yellow-300 font-semibold transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/>
        </svg>
        View on eBay →
      </a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="lg:grid lg:grid-cols-2 lg:gap-14 items-start">

      <!-- Image gallery -->
      <div class="flex flex-col gap-3">
        <div class="rounded-xl overflow-hidden bg-surface-700">
          <img
            id="main-image"
            src={images[0].src}
            alt={images[0].alt}
            class="w-full object-contain max-h-[520px] bg-surface-700"
          />
        </div>
        <div class="grid grid-cols-3 gap-2">
          {images.map((img, i) => (
            <button
              data-src={img.src}
              data-alt={img.alt}
              class:list={[
                'rounded-lg overflow-hidden border-2 transition-all duration-150 focus:outline-none thumbnail-btn aspect-square',
                i === 0 ? 'border-accent' : 'border-white/10 hover:border-accent/40',
              ]}
            >
              <img src={img.src} alt={img.alt} class="w-full h-full object-cover" />
            </button>
          ))}
        </div>
      </div>

      <!-- Details -->
      <div class="mt-10 lg:mt-0">
        <div class="flex items-start justify-between gap-4 mb-1">
          <span class="text-xs font-mono text-accent-light uppercase tracking-widest">RAM · DDR4 ECC RDIMM</span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-accent text-white shadow-lg shadow-accent/30 shrink-0">
            Available
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold mt-2 leading-tight">Micron 64GB DDR4 ECC RDIMM Kit</h1>
        <p class="text-steel font-mono text-sm mt-1">4x 16GB · MTA18ASF2G72PDZ-2G3B1IK · PC4-2400T · 2Rx8</p>

        <div class="flex flex-wrap items-center gap-3 mt-3">
          <span class="px-2.5 py-1 rounded-full text-xs font-medium border text-yellow-400 bg-yellow-400/10 border-yellow-400/20">
            Good
          </span>
          <span class="text-xs text-steel font-mono">Matched set · pulled from working system</span>
        </div>

        <!-- Provenance callout -->
        <div class="mt-6 p-4 rounded-lg bg-surface-700/50 border border-white/10">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="text-sm font-semibold text-slate-300 mb-1">Pulled from a confirmed-working system</p>
              <p class="text-xs text-steel leading-relaxed">
                These sticks came out of an ASUS Z10PE-D16 dual-socket workstation — a system I tested fully before disassembly. All 4 sticks were recognized and running in BIOS. This is a matched set, not a grab bag.
              </p>
            </div>
          </div>
        </div>

        <!-- Market context -->
        <div class="mt-4 p-4 rounded-lg bg-accent/5 border border-accent/20">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <div>
              <p class="text-sm font-semibold text-accent-light mb-1">DDR4 ECC prices are up — not coming down soon</p>
              <p class="text-xs text-steel leading-relaxed">
                DDR4 ECC RDIMM pricing has surged ~90–95% year-over-year through Q1 2026. If you're running a LGA 2011-3 system and need matched ECC RAM, this is a good time to lock it in. Industry relief isn't expected until 2027 at the earliest.
              </p>
            </div>
          </div>
        </div>

        <!-- Write-up -->
        <div class="mt-6">
          <h2 class="text-xs font-mono text-accent-light uppercase tracking-widest mb-3">The Details</h2>
          <div class="space-y-2 text-steel text-sm leading-relaxed">
            <p>
              Matched set of 4x Micron 16GB DDR4-2400 ECC RDIMMs — 64GB total. These are registered ECC sticks, which means they require a platform that supports RDIMMs: Intel C612, C602, C600 chipsets, LGA 2011-3, LGA 2011. Standard desktop boards won't run these.
            </p>
            <p>
              The 2Rx8 organization means each 16GB stick uses 2 ranks with x8 chips — a common configuration with good compatibility across the C612 generation of server and workstation boards. Part number MTA18ASF2G72PDZ-2G3B1IK is directly on the label, readable in the close-up photo.
            </p>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a
            href={ebayUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent/90 transition-colors shadow-lg shadow-accent/20"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/>
            </svg>
            Buy on eBay — $200
          </a>
          <a
            href="/inventory"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg border border-white/10 text-steel hover:text-slate-100 hover:border-white/20 font-medium text-sm transition-colors"
          >
            ← Inventory
          </a>
        </div>

        <p class="mt-4 text-xs text-steel">
          Got a question or want to work something out? Send me a message on eBay — happy to make a deal.
        </p>
      </div>
    </div>

    <!-- Specs table -->
    <div class="mt-16 border-t border-white/5 pt-14">
      <h2 class="text-xl font-bold mb-8">Full Specifications</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5 rounded-xl overflow-hidden border border-white/5">
        {specs.map(spec => (
          <div class="bg-surface-800 px-5 py-4">
            <p class="text-xs text-steel font-mono uppercase tracking-wide mb-1">{spec.label}</p>
            <p class="text-sm text-slate-100 font-medium">{spec.value}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-4 p-6 rounded-xl bg-surface-800 border border-white/10">
      <div>
        <p class="font-semibold text-slate-100">$200 · Available now on eBay</p>
        <p class="text-sm text-steel mt-0.5">USA shipping only · no returns · questions welcome via eBay message</p>
      </div>
      <a
        href={ebayUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent/90 transition-colors shadow-lg shadow-accent/20 shrink-0"
      >
        View on eBay →
      </a>
    </div>

    <!-- Blog link -->
    <div class="mt-6 text-center">
      <a href="/blog/asus-z10pe-d16-dual-socket-flip" class="text-sm text-steel hover:text-accent-light transition-colors underline underline-offset-4">
        Read about the system these came from →
      </a>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>

<script>
  const mainImage = document.getElementById('main-image') as HTMLImageElement;
  const thumbBtns = document.querySelectorAll<HTMLButtonElement>('.thumbnail-btn');

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      mainImage.src = btn.dataset.src!;
      mainImage.alt = btn.dataset.alt!;
      thumbBtns.forEach(b => b.classList.replace('border-accent', 'border-white/10'));
      btn.classList.replace('border-white/10', 'border-accent');
    });
  });
</script>
