---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About" description="Mark's PC Parts — rare and enthusiast hardware from Redlands, CA.">
  <Nav slot="nav" />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl">
      <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-6">About</p>

      <div class="lg:flex lg:gap-14 items-start">

        <!-- Photo placeholder -->
        <div class="hidden lg:flex shrink-0">
          <div class="w-48 h-56 rounded-xl bg-surface-700 border border-white/10 flex flex-col items-center justify-center gap-2 text-steel/30">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="font-mono text-xs">photo</span>
          </div>
        </div>

        <!-- Bio -->
        <div class="space-y-4 text-steel text-base leading-relaxed">
          <p>
            I source parts off eBay deals and Facebook Marketplace meetups. I built this site to
            document some of the crazy hardware I come across, fuck around with it, and then pass
            it on to the next person. That's it.
          </p>
          <p>
            I'm not a professional reseller or running a shop. I just genuinely love this hardware —
            the weird platforms, the obscure flagships, the stuff that never made sense to build a
            normal PC around but exists anyway. When I'm done with something, I sell it.
          </p>
          <p class="text-slate-400">
            Based in Redlands, CA.
          </p>

          <!-- Contact nudge -->
          <div class="pt-4 flex flex-wrap gap-4 text-sm">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 text-accent-light hover:text-white transition-colors font-medium"
            >
              Get in touch →
            </a>
            <a
              href="https://www.tiktok.com/@tacoismybigboydaddy"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-pink-400 hover:text-pink-300 transition-colors font-medium"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.73a4.85 4.85 0 01-1.01-.04z"/></svg>
              TikTok
            </a>
            <a
              href="https://www.ebay.com/usr/markspcparts"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-yellow-400 hover:text-yellow-300 transition-colors font-medium"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/>
              </svg>
              eBay
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
