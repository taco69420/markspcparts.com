---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { label: 'Parts Sourced', value: '200+' },
  { label: 'Rare Finds', value: '50+' },
  { label: 'TikTok Followers', value: 'Growing' },
  { label: 'Based In', value: 'Redlands, CA' },
];

const focuses = [
  { icon: '🔍', title: 'Sourcing', body: 'Estate sales, liquidations, university surplus — finding hardware others overlook.' },
  { icon: '🧪', title: 'Testing', body: 'Every piece is benched, verified, and stress-tested before it gets listed.' },
  { icon: '📝', title: 'Documentation', body: 'Full write-ups with specs, condition notes, and the backstory behind each find.' },
  { icon: '📦', title: 'Rehoming', body: 'Pairing rare hardware with collectors and builders who will actually use it.' },
];
---

<Layout title="About" description="Learn about Mark — rare hardware collector, flipper, and TikTok creator based in Redlands, CA.">
  <Nav slot="nav" />

  <!-- Hero -->
  <section class="relative border-b border-white/5 bg-surface-800 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_80%_at_80%_50%,rgba(124,58,237,0.08),transparent)]" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-2xl">
        <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-4">About</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
          Rare hardware collector<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-light to-violet-300">
            &amp; content creator
          </span>
        </h1>
        <p class="mt-6 text-steel text-lg leading-relaxed">
          Based in Redlands, CA. I find hardware that time forgot, document it properly,
          and send it somewhere it'll be appreciated.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8">
        {stats.map(stat => (
          <div class="text-center sm:text-left">
            <p class="text-2xl sm:text-3xl font-bold text-accent-light">{stat.value}</p>
            <p class="text-sm text-steel mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="lg:grid lg:grid-cols-5 lg:gap-16 items-start">

      <!-- Image placeholder -->
      <div class="hidden lg:flex lg:col-span-2 justify-center">
        <div class="w-64 h-80 rounded-2xl bg-surface-700 border border-white/10 flex flex-col items-center justify-center gap-3 text-steel/40">
          <svg class="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="font-mono text-xs">photo</span>
        </div>
      </div>

      <!-- Bio text -->
      <div class="lg:col-span-3 space-y-5 text-steel leading-relaxed">
        <p>
          I've been taking apart and rebuilding computers since I was a kid. What started as
          a hobby turned into an obsession with tracking down hardware that most people have
          already forgotten about.
        </p>
        <p>
          My focus is on CPU and GPU architecture history — particularly the enthusiast-grade
          chips and boards from the mid-2000s through the early 2020s. Sandy Bridge-E, Fermi,
          Maxwell, Bulldozer — eras that defined the high-performance PC market and produced
          hardware that still has real character.
        </p>
        <p>
          I source from estate sales, university surplus, liquidations, and the occasional
          lucky eBay find. Each piece I bring in gets cleaned, tested, and written up before
          it hits the inventory. If something doesn't pass the bench, it doesn't get listed.
        </p>
        <p>
          I also create content on TikTok covering rare builds, hardware history, and the
          stories behind specific chips and boards. If a piece of hardware has an interesting
          origin, I want to tell that story.
        </p>
        <p class="text-sm">
          Have something rare you're looking to offload, or a question about a specific piece?{' '}
          <a href="/contact" class="text-accent-light hover:text-white transition-colors underline underline-offset-2">
            Reach out.
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- What I do -->
  <section class="border-t border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-3">Process</p>
      <h2 class="text-2xl font-bold mb-10">How it works</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {focuses.map(item => (
          <div class="bg-surface-700 rounded-xl p-6 border border-white/5 hover:border-accent/20 transition-colors">
            <span class="text-2xl mb-3 block">{item.icon}</span>
            <h3 class="font-semibold text-slate-100 mb-2">{item.title}</h3>
            <p class="text-sm text-steel leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
