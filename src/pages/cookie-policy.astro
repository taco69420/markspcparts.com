---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Cookie Policy" description="Cookie policy for markspcparts.com">
  <Nav slot="nav" />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold text-slate-100 mb-2">Cookie Policy</h1>
    <p class="text-sm text-steel mb-10">Last updated: March 26, 2026</p>

    <div class="prose prose-invert prose-sm max-w-none space-y-8 text-steel leading-relaxed">

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">What are cookies</h2>
        <p>
          Cookies are small text files stored in your browser when you visit a website. They're used to remember preferences and track how people use a site.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">How this site uses cookies</h2>
        <p>
          This site uses <strong class="text-slate-300">one category of cookies only: analytics</strong>, and only if you choose to accept them. There are no advertising cookies, no social media tracking pixels, and no third-party embeds that set cookies without your knowledge.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Analytics cookies (optional)</h2>
        <p>
          If you accept cookies, this site loads <strong class="text-slate-300">Google Analytics 4</strong> (GA4), which sets the following cookies:
        </p>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-2 pr-4 text-slate-300 font-medium">Cookie</th>
                <th class="text-left py-2 pr-4 text-slate-300 font-medium">Purpose</th>
                <th class="text-left py-2 text-slate-300 font-medium">Duration</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <tr>
                <td class="py-2 pr-4 font-mono text-xs text-accent-light">_ga</td>
                <td class="py-2 pr-4">Distinguishes unique visitors</td>
                <td class="py-2">2 years</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-mono text-xs text-accent-light">_ga_*</td>
                <td class="py-2 pr-4">Maintains session state for GA4</td>
                <td class="py-2">2 years</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mt-4">
          These cookies collect anonymized data — page views, session duration, approximate location, browser and device type. They do not collect personally identifiable information.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Your consent choice</h2>
        <p>
          When you first visit this site, a banner asks whether you want to accept or decline analytics cookies. If you decline, no cookies are set and Google Analytics does not load at all — there is no tracking of any kind.
        </p>
        <p class="mt-3">
          Your choice is saved in your browser's <strong class="text-slate-300">local storage</strong> (not a cookie) so the banner doesn't appear on every page.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Withdrawing consent</h2>
        <p>To withdraw consent and stop analytics tracking:</p>
        <ul class="mt-3 space-y-1 list-disc list-inside">
          <li>Clear local storage for this site in your browser's developer tools</li>
          <li>Or clear all site data for markspcparts.com in your browser's privacy settings</li>
          <li>Or use your browser's built-in tracking protection</li>
        </ul>
        <p class="mt-3">
          After clearing, the banner will reappear on your next visit.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-200 mb-3">More information</h2>
        <p>
          For details on how Google processes analytics data, see <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-accent-light hover:text-slate-300 underline underline-offset-2 transition-colors">Google's privacy policy</a>.
        </p>
        <p class="mt-3">
          For anything else, use the <a href="/contact" class="text-accent-light hover:text-slate-300 underline underline-offset-2 transition-colors">contact page</a>.
        </p>
      </section>

    </div>
  </div>

  <Footer slot="footer" />
</Layout>
