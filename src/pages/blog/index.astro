---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { readingTime } from '../../lib/readingTime';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Layout title="Blog" description="Hardware writeups, debug logs, and build notes from Mark's PC Parts.">
  <Nav slot="nav" />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-6">Blog</p>
    <h1 class="text-3xl font-semibold text-slate-100 mb-2">Build logs &amp; debug notes</h1>
    <p class="text-steel text-base mb-10">Hardware writeups. What broke, what worked, what I'm running next.</p>

    {/* Tag filter buttons */}
    <div class="flex flex-wrap gap-2 mb-12" id="tag-filters">
      <button
        data-tag="all"
        class="tag-btn text-xs font-mono px-3 py-1 rounded border transition-colors border-accent bg-accent text-white"
      >
        All
      </button>
      {allTags.map(tag => (
        <button
          data-tag={tag}
          class="tag-btn text-xs font-mono px-3 py-1 rounded border transition-colors border-white/10 bg-surface-700 text-steel hover:border-accent-light hover:text-accent-light"
        >
          {tag}
        </button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-steel">No posts yet.</p>
    ) : (
      <ul class="divide-y divide-white/5" id="post-list">
        {posts.map(post => {
          const dateStr = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            timeZone: 'UTC',
          });
          return (
            <li class="py-8 group" data-tags={post.data.tags.join(',')}>
              <a href={`/blog/${post.slug}`} class="block">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-6">
                  <div class="flex items-center gap-2 shrink-0 mb-2 sm:mb-0">
                    <time class="text-xs font-mono text-steel">{dateStr}</time>
                    <span class="text-white/15 text-xs hidden sm:inline">·</span>
                    <span class="text-xs font-mono text-steel hidden sm:inline">{readingTime(post.body)}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h2 class="text-lg font-medium text-slate-100 group-hover:text-accent-light transition-colors mb-1">
                      {post.data.title}
                    </h2>
                    {post.data.description && (
                      <p class="text-steel text-sm leading-relaxed mb-3">{post.data.description}</p>
                    )}
                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.map(tag => (
                          <button
                            data-tag={tag}
                            class="post-tag text-xs font-mono px-2 py-0.5 rounded bg-surface-700 text-steel border border-white/5 hover:border-accent-light hover:text-accent-light transition-colors"
                            onclick="event.preventDefault(); event.stopPropagation(); filterByTag(this.dataset.tag)"
                          >
                            {tag}
                          </button>
                        ))}
                      </div>
                    )}
                  </div>
                  <span class="hidden sm:inline-block shrink-0 text-accent-light opacity-0 group-hover:opacity-100 transition-opacity text-sm">
                    →
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  const ACTIVE = 'border-accent bg-accent text-white';
  const INACTIVE = 'border-white/10 bg-surface-700 text-steel hover:border-accent-light hover:text-accent-light';

  function filterByTag(tag: string) {
    const posts = document.querySelectorAll<HTMLElement>('#post-list li');
    const buttons = document.querySelectorAll<HTMLElement>('.tag-btn');

    buttons.forEach(btn => {
      const isActive = btn.dataset.tag === tag;
      btn.className = `tag-btn text-xs font-mono px-3 py-1 rounded border transition-colors ${isActive ? ACTIVE : INACTIVE}`;
    });

    posts.forEach(li => {
      const tags = li.dataset.tags ? li.dataset.tags.split(',') : [];
      li.style.display = (tag === 'all' || tags.includes(tag)) ? '' : 'none';
    });

    // sync inline post-tag chips highlight
    document.querySelectorAll<HTMLElement>('.post-tag').forEach(chip => {
      const isActive = chip.dataset.tag === tag && tag !== 'all';
      chip.classList.toggle('border-accent', isActive);
      chip.classList.toggle('text-accent-light', isActive);
      chip.classList.toggle('border-white/5', !isActive);
      chip.classList.toggle('text-steel', !isActive);
    });
  }

  // wire up top filter buttons
  document.querySelectorAll<HTMLElement>('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => filterByTag(btn.dataset.tag!));
  });
</script>
