---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const contactMethods = [
  {
    label: 'TikTok',
    handle: '@tacoismybigboydaddy',
    url: 'https://www.tiktok.com/@tacoismybigboydaddy',
    description: 'Follow builds, rare finds, and hardware history.',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.73a4.85 4.85 0 01-1.01-.04z"/></svg>`,
    color: 'text-pink-400',
    bg: 'bg-pink-400/10 border-pink-400/20 hover:border-pink-400/40',
  },
  {
    label: 'eBay Store',
    handle: 'markspcparts',
    description: 'Browse sold listings and active auctions.',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/></svg>`,
    color: 'text-yellow-400',
    bg: 'bg-yellow-400/10 border-yellow-400/20 hover:border-yellow-400/40',
  },
  {
    label: 'Email',
    handle: 'mark@markspcparts.com',
    description: 'For purchase inquiries and part offers.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    color: 'text-sky-400',
    bg: 'bg-sky-400/10 border-sky-400/20 hover:border-sky-400/40',
  },
];

const faqs = [
  {
    q: 'Do you ship outside the US?',
    a: 'Currently US-only for direct sales. International buyers should check the eBay listings which support global shipping.',
  },
  {
    q: 'Can I request a specific part?',
    a: 'Absolutely. Send me an email with what you\'re looking for. If I come across it, I\'ll reach out first.',
  },
  {
    q: 'Do you accept trades?',
    a: 'Occasionally, depending on the item. Reach out with what you have and what you\'re interested in.',
  },
  {
    q: 'Are parts tested before listing?',
    a: 'Yes — every piece is benched and stress-tested. Condition is rated honestly. No "untested" listings.',
  },
];
---

<Layout title="Contact" description="Get in touch with Mark — inquiries about rare PC hardware, part requests, and more.">
  <Nav slot="nav" />

  <!-- Header -->
  <section class="border-b border-white/5 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-xs font-mono text-accent-light uppercase tracking-widest mb-3">Contact</p>
      <h1 class="text-3xl sm:text-4xl font-bold">Get in Touch</h1>
      <p class="mt-3 text-steel max-w-lg">
        Questions about a specific piece, want to sell something, or just want to talk hardware?
        Here's where to find me.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="lg:grid lg:grid-cols-2 lg:gap-20 items-start">

      <!-- Contact methods -->
      <div>
        <h2 class="text-xl font-semibold mb-6">Reach Out</h2>
        <div class="flex flex-col gap-4">
          {contactMethods.map(method => (
            <div class:list={['flex items-start gap-4 p-5 rounded-xl border transition-colors', method.bg]}>
              <span class:list={['mt-0.5 shrink-0', method.color]} set:html={method.icon} />
              <div>
                <p class="font-semibold text-slate-100 text-sm">{method.label}</p>
                {method.url
                  ? <a href={method.url} target="_blank" rel="noopener noreferrer" class:list={['text-sm font-mono mt-0.5 hover:underline underline-offset-2', method.color]}>{method.handle}</a>
                  : <p class:list={['text-sm font-mono mt-0.5', method.color]}>{method.handle}</p>
                }
                <p class="text-xs text-steel mt-1">{method.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 p-5 rounded-xl bg-surface-700 border border-white/5">
          <div class="flex items-center gap-2 text-sm text-steel mb-1">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Location
          </div>
          <p class="text-slate-100 font-medium">Redlands, CA</p>
          <p class="text-xs text-steel mt-1">Local pickup available for select items.</p>
        </div>
      </div>

      <!-- FAQs -->
      <div class="mt-14 lg:mt-0">
        <h2 class="text-xl font-semibold mb-6">Common Questions</h2>
        <div class="flex flex-col divide-y divide-white/5">
          {faqs.map(item => (
            <div class="py-5 first:pt-0 last:pb-0">
              <h3 class="text-sm font-semibold text-slate-100 mb-2">{item.q}</h3>
              <p class="text-sm text-steel leading-relaxed">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
