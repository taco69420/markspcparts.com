---
export interface Props {
  name: string;
  category: string;
  specs: string[];
  condition: 'Mint' | 'Excellent' | 'Good' | 'Fair';
  status: 'Available' | 'Sold' | 'Not Listed';
  description: string;
  ebayUrl?: string;
  image?: string;
  href?: string;
}

const {
  name,
  category,
  specs,
  condition,
  status,
  description,
  ebayUrl,
  image,
  href,
} = Astro.props;

const conditionColor: Record<string, string> = {
  Mint: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
  Excellent: 'text-sky-400 bg-sky-400/10 border-sky-400/20',
  Good: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20',
  Fair: 'text-orange-400 bg-orange-400/10 border-orange-400/20',
};

const statusBadge: Record<string, string> = {
  Available: 'bg-accent text-white shadow-lg shadow-accent/30',
  Sold: 'bg-slate-700 text-slate-400',
  'Not Listed': 'bg-amber-500/20 text-amber-300 border border-amber-500/30',
};
---

<div class:list={[
  'group relative flex flex-col rounded-xl border transition-all duration-200 overflow-hidden',
  status === 'Sold'
    ? 'border-white/5 bg-surface-800 opacity-70'
    : 'border-white/10 bg-surface-800 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/5',
]}>
  <!-- Image area -->
  <div class="relative aspect-[4/3] bg-surface-700 flex items-center justify-center overflow-hidden">
    {image ? (
      <img src={image} alt={name} class="w-full h-full object-cover" />
    ) : (
      <div class="flex flex-col items-center gap-2 text-steel/40">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
        </svg>
        <span class="font-mono text-xs">no image</span>
      </div>
    )}

    <!-- Status badge -->
    <span class:list={[
      'absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-semibold tracking-wide',
      statusBadge[status],
    ]}>
      {status}
    </span>

    <!-- Category tag -->
    <span class="absolute top-3 left-3 px-2 py-0.5 rounded bg-black/50 backdrop-blur-sm text-xs text-steel font-mono">
      {category}
    </span>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <div>
      <h3 class:list={[
        'text-base font-semibold text-slate-100 leading-tight transition-colors',
        href ? 'group-hover:text-accent-light' : '',
      ]}>
        {href ? <a href={href} class="after:absolute after:inset-0">{name}</a> : name}
      </h3>
      <p class="mt-1.5 text-sm text-steel leading-relaxed">{description}</p>
    </div>

    <!-- Specs -->
    <ul class="flex flex-col gap-1">
      {specs.map(spec => (
        <li class="flex items-start gap-2 text-xs text-steel/80 font-mono">
          <span class="text-accent-light mt-px select-none">›</span>
          <span>{spec}</span>
        </li>
      ))}
    </ul>

    <!-- Bottom row -->
    <div class="mt-auto pt-3 border-t border-white/5 flex items-center justify-between gap-3">
      <span class:list={[
        'px-2.5 py-1 rounded-full text-xs font-medium border',
        conditionColor[condition],
      ]}>
        {condition}
      </span>

      {status === 'Sold' && ebayUrl && (
        <a
          href={ebayUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 flex items-center gap-1.5 text-xs text-yellow-400 hover:text-yellow-300 transition-colors font-medium"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/>
          </svg>
          View on eBay
        </a>
      )}

      {status === 'Available' && ebayUrl && (
        <a
          href={ebayUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 flex items-center gap-1 text-xs text-yellow-400 hover:text-yellow-300 transition-colors font-medium"
        >
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/></svg>
          eBay →
        </a>
      )}

      {status === 'Available' && !href && !ebayUrl && (
        <a href="/contact" class="relative z-10 text-xs text-accent-light hover:text-white transition-colors font-medium">
          Inquire →
        </a>
      )}

      {status === 'Available' && href && !ebayUrl && (
        <span class="text-xs text-accent-light font-medium">View listing →</span>
      )}

      {status === 'Not Listed' && href && (
        <span class="text-xs text-amber-400/80 font-medium font-mono">View listing →</span>
      )}
    </div>
  </div>
</div>
