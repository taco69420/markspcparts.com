---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-surface-800 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center sm:items-start gap-1">
        <span class="font-mono text-accent-light text-sm font-medium tracking-tight">
          &gt; markspcparts
        </span>
        <span class="text-xs text-steel">Redlands, CA · Rare &amp; Enthusiast Hardware</span>
      </div>

      <div class="flex items-center gap-6 text-xs text-steel">
        <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
        <a href="/inventory" class="hover:text-slate-300 transition-colors">Inventory</a>
        <a href="/about" class="hover:text-slate-300 transition-colors">About</a>
        <a href="/contact" class="hover:text-slate-300 transition-colors">Contact</a>
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-white/5 text-center text-xs text-surface-600 text-slate-600">
      &copy; {year} Mark's PC Parts · markspcparts.com
    </div>
  </div>
</footer>
